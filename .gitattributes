# Normalize common text files to LF across platforms.
*.cs text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.toml text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Unity text-serialized assets.
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.inputactions text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf

# Common binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.tga binary
*.psd binary
*.fbx binary
*.blend binary
*.wav binary
*.mp3 binary
*.mp4 binary
*.ttf binary
*.otf binary
*.dll binary
*.exe binary
*.apk binary
*.jar binary
